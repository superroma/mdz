    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "mnemonist": "^0.39.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.1",
    "get-func-name": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "5.5.4",
    "vitest": "^1.6.0"
