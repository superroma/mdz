{
  "name": "@app/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "dev": "PAGES_ROOT=../../pages tsx watch src/server.ts",
    "serve": "PAGES_ROOT=../../pages tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "PAGES_ROOT=../../pages node dist/server.js",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^7.0.4",
    "fastify": "^4.29.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.1",
    "tsx": "^4.19.0",
    "typescript": "5.5.4",
    "vitest": "^1.6.0"
  }
}
