{
  "name": "@app/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "dev": "node --import tsx/esm --watch src/dev-server.ts",
    "serve": "node --import tsx/esm src/dev-server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "admin": "node --import tsx/esm src/cli/admin.ts",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^9.0.0",
    "@fastify/oauth2": "^8.1.2",
    "@fastify/static": "^8.0.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.2.0",
    "jsonwebtoken": "^9.0.2",
    "mnemonist": "^0.39.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.1",
    "get-func-name": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "5.5.4",
    "vitest": "^1.6.0"
  }
}
