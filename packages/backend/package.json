{
  "name": "@app/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "dev": "PAGES_ROOT=../../pages tsx watch src/server.ts",
    "serve": "PAGES_ROOT=../../pages tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
